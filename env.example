# ============================================================
# WASH Tracker API — Variables d'environnement
# Copier en .env et remplir les valeurs
# ============================================================

NODE_ENV=development
PORT=3000

# Base de données MongoDB
MONGO_URI=mongodb://localhost:27017/wash_tracker

# JWT Secrets (générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=changez_ce_secret_jwt_tres_long_et_aleatoire_en_production
JWT_REFRESH_SECRET=changez_ce_secret_refresh_different_du_jwt_secret

# CORS — URLs autorisées (séparées par virgule)
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8081,http://127.0.0.1:8081,https://dash.wash-tracker.bf

# Upload photos (optionnel)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# Firebase (notifications push — optionnel)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
